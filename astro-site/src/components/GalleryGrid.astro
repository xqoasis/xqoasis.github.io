---
interface Image {
  image_path: string;
  url?: string;
  alt?: string;
}

interface Props {
  images: Image[];
  layout?: 'single' | 'half' | 'third';
  caption?: string;
}

const { images, layout = 'half', caption } = Astro.props;
---

<div class={`gallery-grid layout-${layout}`}>
  {images.map(img => (
    <div class="gallery-item" data-full={img.url || img.image_path}>
      <img src={img.image_path} alt={img.alt || ''} loading="lazy" />
    </div>
  ))}
</div>
{caption && <p class="gallery-caption">{caption}</p>}
