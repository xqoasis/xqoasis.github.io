<!-- Lightbox component: click any .gallery-item img to open -->
<div class="lightbox-overlay" id="lightbox">
  <button class="lightbox-close" aria-label="Close">&times;</button>
  <button class="lightbox-nav lightbox-prev" aria-label="Previous">&lsaquo;</button>
  <button class="lightbox-nav lightbox-next" aria-label="Next">&rsaquo;</button>
  <img src="" alt="" id="lightbox-img" />
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const overlay = document.getElementById('lightbox') as HTMLDivElement;
    const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const items = Array.from(document.querySelectorAll('.gallery-item'));
    let currentIndex = 0;

    function getFullUrl(item: Element): string {
      return item.getAttribute('data-full') || (item.querySelector('img') as HTMLImageElement)?.src || '';
    }

    function open(index: number) {
      currentIndex = index;
      lbImg.src = getFullUrl(items[index]);
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      overlay.classList.remove('active');
      document.body.style.overflow = '';
    }

    function navigate(dir: number) {
      currentIndex = (currentIndex + dir + items.length) % items.length;
      lbImg.src = getFullUrl(items[currentIndex]);
    }

    items.forEach((item, i) => {
      item.addEventListener('click', (e) => {
        e.preventDefault();
        open(i);
      });
    });

    overlay.querySelector('.lightbox-close')!.addEventListener('click', close);
    overlay.querySelector('.lightbox-prev')!.addEventListener('click', (e) => { e.stopPropagation(); navigate(-1); });
    overlay.querySelector('.lightbox-next')!.addEventListener('click', (e) => { e.stopPropagation(); navigate(1); });
    overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });

    document.addEventListener('keydown', (e) => {
      if (!overlay.classList.contains('active')) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') navigate(-1);
      if (e.key === 'ArrowRight') navigate(1);
    });
  });
</script>
